{
  "name": "@gradata/cli",
  "version": "0.1.0",
  "description": "Gradata CLI and correction-event client for JS/TS apps. Shells to the Python SDK for heavy lifting; ships a lightweight JS client for emitting correction events to a local Gradata daemon.",
  "license": "AGPL-3.0-or-later",
  "author": "Gradata <oliver@gradata.com>",
  "homepage": "https://github.com/Gradata/gradata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gradata/gradata.git",
    "directory": "packages/npm"
  },
  "bugs": {
    "url": "https://github.com/Gradata/gradata/issues"
  },
  "keywords": [
    "gradata",
    "ai",
    "memory",
    "learning",
    "corrections",
    "agents",
    "llm"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/client.js",
  "module": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "bin": {
    "gradata": "./bin/gradata.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
