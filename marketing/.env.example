# Marketing site environment variables.
# Copy to .env.local for dev. Set in Cloudflare Pages dashboard for prod.
#
# See also: ../cloud/RAILWAY-ENV.md for backend env vars (they live on Railway,
# not here — but Oliver's env docs all live in RAILWAY-ENV.md so check both).

# ── Analytics (Plausible, privacy-first, no cookies) ───────────────────
# Set to "true" in production builds only. Leave unset in dev/preview so
# localhost traffic doesn't pollute the dashboard.
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Domain registered in Plausible. Defaults to gradata.ai when unset.
# Plausible groups stats by this value — must match the domain the site
# is actually served from.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=gradata.ai

# Tracked events (fired client-side when analytics is enabled):
#   signup_click      - any "Sign up" / "Get started" CTA click
#   signup_complete   - user lands on /?signup=success after Supabase verify
#   docs_click        - "Docs" nav link click
#   install_copy      - hero install-command copy button click
