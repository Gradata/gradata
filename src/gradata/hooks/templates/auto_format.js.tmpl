#!/usr/bin/env node
/**
 * Generated by gradata rule_to_hook.
 * Rule: {{RULE_TEXT}}
 * Source hash: {{SOURCE_HASH}}
 * Template: auto_format
 *
 * PostToolUse hook. After an Edit/Write touches a formattable file, runs
 * the matching formatter in-place. Fail-open: never blocks the session if
 * the formatter is missing or errors. Skips if the edited path is itself
 * a formatter config to avoid edit -> format -> edit loops.
 *
 *   .py                    -> `ruff format <file>`
 *   .js / .jsx / .ts /
 *   .tsx / .md / .yaml /
 *   .yml / .json / .css    -> `prettier --write <file>`
 *
 * Override: set GRADATA_BYPASS=1 or GRADATA_NO_AUTOFORMAT=1 to skip.
 */
const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

if (process.env.GRADATA_BYPASS === '1') process.exit(0);
if (process.env.GRADATA_NO_AUTOFORMAT === '1') process.exit(0);

let input;
try {
  if (process.stdin.isTTY) process.exit(0);
  input = JSON.parse(fs.readFileSync(0, 'utf8'));
} catch { process.exit(0); }

try {
  const toolInput = input.tool_input || {};
  const filePath = toolInput.file_path || '';
  if (!filePath) process.exit(0);

  // Skip formatter config files to avoid format->edit->format loops.
  const base = path.basename(filePath).toLowerCase();
  const loopBait = new Set([
    '.prettierrc', '.prettierrc.json', '.prettierrc.yaml', '.prettierrc.yml',
    '.prettierrc.js', '.prettierrc.cjs', 'prettier.config.js', 'prettier.config.cjs',
    '.prettierignore', 'ruff.toml', '.ruff.toml', 'pyproject.toml',
  ]);
  if (loopBait.has(base)) process.exit(0);

  const ext = path.extname(filePath).toLowerCase();
  const prettierExts = new Set([
    '.js', '.jsx', '.ts', '.tsx', '.md', '.mdx',
    '.yaml', '.yml', '.json', '.jsonc', '.css', '.scss', '.html',
  ]);

  let cmd, args;
  if (ext === '.py') {
    cmd = 'ruff';
    args = ['format', filePath];
  } else if (prettierExts.has(ext)) {
    // npx resolves prettier if installed locally or globally.
    cmd = process.platform === 'win32' ? 'npx.cmd' : 'npx';
    args = ['--no-install', 'prettier', '--write', '--log-level', 'warn', filePath];
  } else {
    process.exit(0);
  }

  const res = spawnSync(cmd, args, {
    encoding: 'utf-8',
    timeout: 15000,
    shell: false,
  });

  // spawnSync could not reach the formatter (ENOENT, not installed, etc).
  // Warn once on stderr so Claude sees it next turn — never block.
  if (res.error || res.status === null) {
    process.stderr.write(
      `WARNING: auto_format skipped ${filePath} — ${cmd} not available. ` +
      `Install it or set GRADATA_NO_AUTOFORMAT=1 to silence.\n`
    );
    process.exit(0);
  }

  // Non-zero formatter exit is advisory only — surface but do not block.
  if (res.status !== 0) {
    const tail = ((res.stderr || '') + (res.stdout || '')).slice(-400);
    process.stderr.write(
      `WARNING: auto_format ${cmd} exited ${res.status} on ${filePath}:\n${tail}\n`
    );
  }
} catch (e) {
  // Never break the session on a hook error.
  process.exit(0);
}
process.exit(0);
