#!/usr/bin/env node
/**
 * Generated by gradata rule_to_hook.
 * Rule: {{RULE_TEXT}}
 * Source hash: {{SOURCE_HASH}}
 * Template: notify_waiting
 *
 * Stop hook. Fires a native OS notification when Claude finishes a turn so
 * the user can walk away during long thinks. Cross-platform:
 *
 *   linux   -> notify-send
 *   darwin  -> osascript -e 'display notification ...'
 *   win32   -> powershell -Command (BurntToast fallback: msg-box via WScript)
 *
 * Fail-open: if the notifier is missing or fails, exits 0. Never blocks
 * the session.
 *
 * Body: last non-empty line of the assistant's last message, truncated to
 * 100 chars. Title: "Claude finished".
 *
 * Override: set GRADATA_BYPASS=1 or GRADATA_NO_NOTIFY=1 to skip. CI
 * environments are auto-detected (CI=true) and skipped.
 */
const fs = require('fs');
const { spawn } = require('child_process');

if (process.env.GRADATA_BYPASS === '1') process.exit(0);
if (process.env.GRADATA_NO_NOTIFY === '1') process.exit(0);
// Never notify in CI — there's no user to see it and the notifier may hang.
if (process.env.CI === 'true' || process.env.CI === '1') process.exit(0);

let input;
try {
  if (process.stdin.isTTY) process.exit(0);
  input = JSON.parse(fs.readFileSync(0, 'utf8'));
} catch { process.exit(0); }

function extractLastLine(payload) {
  // Try several known shapes for the trailing assistant message.
  const candidates = [
    payload.assistant_message,
    payload.last_message,
    payload.message && payload.message.content,
    payload.transcript,
  ];
  for (const c of candidates) {
    if (typeof c !== 'string' || !c.trim()) continue;
    const lines = c.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
    if (lines.length) return lines[lines.length - 1];
  }
  return 'Turn complete.';
}

function truncate(s, n) {
  if (!s) return '';
  return s.length > n ? s.slice(0, n - 1) + '\u2026' : s;
}

function shellQuoteSingle(s) {
  // Safe single-quote wrapping for POSIX + osascript.
  return "'" + String(s).replace(/'/g, "'\\''") + "'";
}

function shellQuotePS(s) {
  // PowerShell single-quote escaping — doubles the quote.
  return "'" + String(s).replace(/'/g, "''") + "'";
}

const title = 'Claude finished';
const body = truncate(extractLastLine(input), 100);

try {
  let cmd, args;
  if (process.platform === 'linux') {
    cmd = 'notify-send';
    args = ['--app-name=Claude', title, body];
  } else if (process.platform === 'darwin') {
    cmd = 'osascript';
    args = [
      '-e',
      `display notification ${shellQuoteSingle(body)} with title ${shellQuoteSingle(title)}`,
    ];
  } else if (process.platform === 'win32') {
    cmd = 'powershell.exe';
    // BurntToast is optional; fall back to MessageBox-style balloon via
    // WScript.Shell Popup (non-blocking with 3s timeout).
    const ps = `
      $ErrorActionPreference = 'SilentlyContinue';
      try {
        Import-Module BurntToast -ErrorAction Stop;
        New-BurntToastNotification -Text ${shellQuotePS(title)}, ${shellQuotePS(body)};
      } catch {
        $sh = New-Object -ComObject WScript.Shell;
        [void]$sh.Popup(${shellQuotePS(body)}, 3, ${shellQuotePS(title)}, 64);
      }
    `;
    args = ['-NoProfile', '-NonInteractive', '-Command', ps];
  } else {
    process.exit(0);
  }

  const child = spawn(cmd, args, {
    stdio: 'ignore',
    detached: true,
    windowsHide: true,
  });
  child.on('error', () => { /* fail-open */ });
  // Don't block the Stop hook on the notifier.
  child.unref();
} catch (e) {
  // Never break on notifier error.
}
process.exit(0);
