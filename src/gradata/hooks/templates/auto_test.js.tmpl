#!/usr/bin/env node
/**
 * Generated by gradata rule_to_hook.
 * Rule: {{RULE_TEXT}}
 * Source hash: {{SOURCE_HASH}}
 * Template: auto_test
 * Runs pytest against test_<basename>.py if found near the edited file.
 * Scope: pytest only (v1). Prints failure summary but exits 0 — relies on
 * Claude seeing the output and reacting on next turn.
 */
const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

if (process.env.GRADATA_BYPASS === '1') process.exit(0);

let input;
try {
  if (process.stdin.isTTY) process.exit(0);
  input = JSON.parse(fs.readFileSync(0, 'utf8'));
} catch { process.exit(0); }

try {
  const toolInput = input.tool_input || {};
  const filePath = toolInput.file_path || '';
  if (!filePath.endsWith('.py')) process.exit(0);

  const dir = path.dirname(filePath);
  const base = path.basename(filePath, '.py');

  const candidates = [
    path.join(dir, `test_${base}.py`),
    path.join(dir, '..', 'tests', `test_${base}.py`),
    path.join('tests', `test_${base}.py`),
  ];
  const testFile = candidates.find(p => { try { return fs.statSync(p).isFile(); } catch { return false; } });
  if (!testFile) process.exit(0);

  const res = spawnSync('python', ['-m', 'pytest', testFile, '--tb=short', '-q'], {
    encoding: 'utf-8', timeout: 30000,
  });
  if (res.status !== 0) {
    // Advisory signal — hooks in this directory MUST fail open. Surface the
    // pytest output via stderr so Claude can see it on the next turn, but
    // exit 0 so the tool chain is not blocked.
    const summary = `WARNING: Tests failed for ${testFile} after editing ${filePath}:\n${(res.stdout || '').slice(-800)}\n${(res.stderr || '').slice(-400)}\n\nRule: {{RULE_TEXT}}. Fix before moving on.`;
    process.stderr.write(summary + '\n');
  }
} catch (e) {
  // Never break the session on a hook error
  process.exit(0);
}
process.exit(0);
