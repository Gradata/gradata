LINKEDIN_WRITES=brain/prospects/*
LINKEDIN_REQUIRES=profile_visited,gate_complete

# LISTBUILD contract:
LISTBUILD_READS=Leads/*,brain/prospects/*
LISTBUILD_WRITES=Leads/*,brain/prospects/*
LISTBUILD_REQUIRES=icp_criteria_loaded
