DEMOPREP_WRITES=brain/prospects/*,docs/Demo Prep/*
DEMOPREP_REQUIRES=calendar_confirmed,vault_note_exists_or_created,gate_complete

# LOOPCORE contract:
LOOPCORE_READS=brain/prospects/*,brain/emails/PATTERNS.md
LOOPCORE_WRITES=brain/prospects/*
LOOPCORE_REQUIRES=prospect_notes_scanned

# LOOPADV contract:
LOOPADV_READS=brain/prospects/*,brain/emails/PATTERNS.md,brain/system-patterns.md,.claude/audit-log.md
LOOPADV_WRITES=brain/prospects/*,brain/emails/PATTERNS.md,brain/system-patterns.md
LOOPADV_REQUIRES=prospect_notes_scanned,outcomes_checked

# COLDCALL contract:
COLDCALL_READS=brain/prospects/*,brain/personas/*,.claude/lessons.md
COLDCALL_WRITES=brain/prospects/*
COLDCALL_REQUIRES=linkedin_visited,gate_complete

# LINKEDIN contract:
