# ============================================================================
# SKILL CONTRACTS (inspired by oswalpalash/ontology)
# ============================================================================
# Each domain declares what data it reads and writes. This makes dependencies
# explicit for SDK portability — any domain can be extracted as a standalone
# skill because its data contract is declared, not implicit.
#
# Format:
#   {DOMAIN}_READS=file1,file2,...
#   {DOMAIN}_WRITES=file1,file2,...
#   {DOMAIN}_REQUIRES=precondition1,precondition2,...
#
# PROSPECTEMAIL contract:
PROSPECTEMAIL_READS=brain/prospects/*,brain/emails/PATTERNS.md,brain/personas/*,.claude/lessons.md
PROSPECTEMAIL_WRITES=brain/prospects/*,brain/emails/PATTERNS.md
PROSPECTEMAIL_REQUIRES=vault_note_exists_or_created,patterns_read,gate_complete

# DEMOPREP contract:
