# CARL Manifest
# ==============
# Controls which domains are active and how they're triggered.

# ============================================================================
# PRIORITY SYSTEM
# ============================================================================
# CRITICAL = always load, never compress (truth, data integrity, cost)
# HIGH = load at session start (daily operations)
# NORMAL = load on demand when task triggers (optimization, analytics)
# Startup loads: CRITICAL + HIGH. NORMAL loads when relevant gate fires.
# ============================================================================
#
# Format:
#   DEVMODE=true|false                (debug output in responses)
#   {DOMAIN}_STATE=active|inactive    (whether domain is enabled)
#   {DOMAIN}_ALWAYS_ON=true|false     (load every prompt, no keyword matching)
#   {DOMAIN}_RECALL=keyword1,keyword2 (triggers on-demand loading)
#   {DOMAIN}_EXCLUDE=word1,word2      (skip domain if these words in prompt)
#
# Loading Logic:
#   1. ALWAYS_ON=true domains load every prompt
#   2. Other active domains load when recall keywords match user prompt
#   3. Exclusions are checked before matching

# ============================================================================
# SHADOW MODE SYSTEM
# ============================================================================
# New rules can run in SHADOW mode: they make predictions but don't affect output.
# After 3 sessions of shadow tracking, rules are promoted to ACTIVE or KILLED.
# Format: {RULE}_MODE=ACTIVE|SHADOW|DORMANT
# ACTIVE = affects output (default for existing rules)
# SHADOW = tracks what WOULD have changed, doesn't affect output
# DORMANT = disabled, not loaded
# Promotion: 2/3 shadow predictions would have improved output → ACTIVE
# Kill: 2/3 shadow predictions would have worsened output → KILLED
# ============================================================================

# ============================================================================
# SETTINGS
# ============================================================================
DEVMODE=false

# ============================================================================
# SAFETY - Structural & operational protections (always loaded from .carl/safety)
# ============================================================================
SAFETY_STATE=active
SAFETY_ALWAYS_ON=true
SAFETY_FILE=.carl/safety
SAFETY_PRIORITY=CRITICAL

# ============================================================================
# GLOBAL - Gradata universal rules (always loaded from .carl/global)
# ============================================================================
GLOBAL_STATE=active
GLOBAL_ALWAYS_ON=true

# ============================================================================
# DOMAIN GLOBAL - Domain-specific universal rules (always loaded from domain/carl/global)
# ============================================================================
DOMAINGLOBAL_STATE=active
DOMAINGLOBAL_ALWAYS_ON=true
