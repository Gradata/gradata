# Copy to .env.local and fill in real values. Never commit .env.local.
# NEXT_PUBLIC_* vars are inlined at build time — rebuild after changing them.

# --- Required ---

# Supabase project URL (https://<project>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (publishable) key — safe to expose in client
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me

# Backend API base URL (Railway: https://gradata-production.up.railway.app, prod: https://api.gradata.ai)
NEXT_PUBLIC_API_URL=https://api.gradata.ai

# --- Optional: Sentry runtime (client) ---

# Sentry DSN — leave blank to disable error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Environment label sent with every event (production / staging / preview / development)
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Release identifier — typically gradata-dashboard@<git-sha>
NEXT_PUBLIC_SENTRY_RELEASE=gradata-dashboard@dev

# --- Optional: Sentry build-time (source-map upload) ---
# Only needed if you want stack traces de-minified in Sentry. Set in CI/Cloudflare,
# never commit. Without these, the build still succeeds — just no source maps uploaded.

SENTRY_AUTH_TOKEN=
SENTRY_ORG=gradata
SENTRY_PROJECT=gradata-dashboard
