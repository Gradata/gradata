# .agentignore — Files excluded from agent context
# Uses gitignore syntax. Agent should never read these files
# unless Oliver explicitly asks for them by name.

# Archived prospects (restored on demand only)
brain/archive/
brain/archive/**

# Retired lesson archive (cold storage, excluded from search paths)
.claude/lessons-archive-retired.md

# System evolution (historical reference, not operational)
.claude/system-evolution.md

# Old session notes (captured in loop-state and lessons already)
# Keep last 7 days; older ones should be in brain/sessions/ or deleted
Session Notes/*.md
!Session Notes/2026-03-1[3-9].md
!Session Notes/2026-03-2*.md

# Deprecated CARL files (already deleted, prevent recreation)
.carl/sequence-engine
.carl/example-custom-domain

# Git internals
brain/.git/
brain/.git/**
.git/
.git/**

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini
*.tmp
~$*

# Python cache
__pycache__/
*.pyc

# Editor artifacts
*.swp
*.swo
*~

# Large binary files
*.zip
*.tar.gz
*.rar

# Credential files (never read, never reference)
.env
*.credentials
*.secret
credentials.json
